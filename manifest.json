{
  "name": "Yape",
  "version": "2.1.0",
  "description": "Extension for PyLoad to easily monitor and add downloads",
  "permissions": ["storage", "contextMenus", "notifications"],
  "host_permissions": [],
  "optional_host_permissions": ["http://*/", "https://*/"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon_16.png",
      "32": "images/icon_32.png",
      "48": "images/icon_48.png",
      "128": "images/icon_128.png"
    }
  },
  "icons": {
    "16": "images/icon_16.png",
    "32": "images/icon_32.png",
    "48": "images/icon_48.png",
    "128": "images/icon_128.png"
  },
  "homepage_url": "https://github.com/jsoyer/Yape",
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "default-src 'none'; script-src 'self'; style-src 'self'; img-src 'self'; font-src 'self'; connect-src *; object-src 'none'"
  },
  "manifest_version": 3
}
